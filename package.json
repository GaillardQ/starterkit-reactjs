{
  "name": "happy-fit-planner",
  "homepage": "http://happy-fit-planner.herokuapp.com/",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@date-io/moment": "1.x",
    "@material-ui/core": "^4.9.5",
    "@material-ui/icons": "^4.9.1",
    "@material-ui/lab": "^4.0.0-alpha.45",
    "@material-ui/pickers": "^3.2.10",
    "@testing-library/jest-dom": "^5.11.3",
    "@testing-library/react": "^10.4.8",
    "@testing-library/user-event": "^7.1.2",
    "@types/jest": "^26.0.10",
    "@types/react-dom": "^16.9.8",
    "@types/react-router-dom": "^5.1.3",
    "@types/yup": "^0.26.32",
    "chart.js": "^2.9.3",
    "date-fns": "^2.15.0",
    "formik": "^2.1.4",
    "http-proxy-middleware": "^1.0.2",
    "moment": "^2.27.0",
    "node-sass-chokidar": "^1.4.0",
    "notistack": "^0.9.9",
    "npm-run-all": "^4.1.5",
    "prettier": "^1.19.1",
    "react": "^16.13.0",
    "react-chartjs-2": "^2.9.0",
    "react-dom": "^16.13.0",
    "react-router": "^5.1.2",
    "react-router-dom": "^5.1.2",
    "react-scripts": "3.4.0",
    "typescript": "^3.8.3",
    "yup": "^0.28.3"
  },
  "scripts": {
    "build": "npm-run-all build-css build-js",
    "build-css": "postcss src/Resources/assets/css/tailwind.css -o src/Resources/assets/css/main.css",
    "build-js": "react-scripts build",
    "dev": "npm-run-all -p watch-css start-js",
    "watch-css": "postcss src/Resources/assets/css/tailwind.css -o src/Resources/assets/css/main.css --watch",
    "start-js": "PORT=3003 react-scripts start",
    "lint-staged": "lint-staged",
    "precommit": "lint-staged",
    "start": "react-scripts start",
    "eject": "react-scripts eject",
    "test": "react-scripts test --watchAll=false --env=jsdom --coverage --testResultsProcessor jest-sonar-reporter"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,json,scss, ts, tsx}": [
      "prettier --write",
      "git add"
    ]
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^9.7.1",
    "jest-sonar-reporter": "^2.0.0",
    "postcss-cli": "^6.1.3",
    "postcss-import": "^12.0.1",
    "tailwindcss": "^1.6.2"
  },
  "jest": {
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\][^@testing-library/].+\\.(js|jsx)$"
    ]
  },
  "jestSonar": {
    "reportPath": "reports",
    "reportFile": "test-report.xml",
    "indent": 4
  }
}
